NODE_ENV=production
PORT=4000
API_BASE_PATH=/api
MONGODB_URI=mongodb+srv://USER:PASSWORD@YOUR-CLUSTER.example.mongodb.net/saas_boilerplate?retryWrites=true&w=majority
CORS_ORIGIN=https://your-frontend-domain.example.com

JWT_SECRET=replace-with-a-secure-random-secret-at-least-32-characters
JWT_EXPIRES_IN_SECONDS=3600

# File storage provider. Prefer durable object storage in production.
STORAGE_PROVIDER=azure_blob
STORAGE_LOCAL_ROOT=apps/api/storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=saas-files
AZURE_STORAGE_ACCOUNT_NAME=YOUR_ACCOUNT
AZURE_STORAGE_USE_AZURITE=false

# OIDC / SSO settings
OIDC_STATE_SECRET=replace-with-a-different-secure-random-secret-32-plus-chars
OIDC_STATE_EXPIRES_IN_SECONDS=600
OIDC_HTTP_TIMEOUT_MS=5000
OIDC_FRONTEND_CALLBACK_URL=https://your-frontend-domain.example.com/auth/sso/callback
OIDC_ALLOW_PLAIN_CLIENT_SECRET=false

# Optional seed values. Do not use demo credentials in production.
SEED_ORGANISATION_NAME=Platform Admin Organisation
SEED_ORGANISATION_SLUG=platform-admin
SEED_ORGANISATION_DOMAIN=your-domain.example.com
SEED_ADMIN_EMAIL=admin@your-domain.example.com
SEED_ADMIN_PASSWORD=replace-with-a-secure-temporary-password
SEED_ADMIN_FIRST_NAME=Platform
SEED_ADMIN_LAST_NAME=Admin
SEED_PLAN_KEY=professional
SEED_FORCE_ADMIN_PASSWORD_RESET=false
