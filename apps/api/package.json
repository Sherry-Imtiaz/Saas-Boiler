{
  "name": "@saas-boilerplate/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "seed": "tsx src/scripts/seed.ts",
    "check:install": "tsx src/scripts/checkInstall.ts",
    "reset:dev-data": "tsx src/scripts/resetDevData.ts",
    "check:deployment": "tsx src/scripts/checkDeploymentReadiness.ts",
    "test": "vitest run -c vitest.unit.config.ts",
    "test:unit": "vitest run -c vitest.unit.config.ts",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:watch": "vitest -c vitest.integration.config.ts",
    "test:coverage": "vitest run -c vitest.integration.config.ts --coverage"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.27.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^9.18.0",
    "mongodb-memory-server": "^10.1.4",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  }
}
