NODE_ENV=development
PORT=4000
API_BASE_PATH=/api
MONGODB_URI=mongodb://localhost:27017/saas_boilerplate
CORS_ORIGIN=http://localhost:5173

JWT_SECRET=change-this-local-development-secret-at-least-32-chars
JWT_EXPIRES_IN_SECONDS=3600

# File storage provider
STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=apps/api/storage

# Azure Blob Storage / Azurite-compatible settings
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=saas-files
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_USE_AZURITE=false


# OIDC / SSO settings
# OIDC_STATE_SECRET signs stateless SSO state. Leave empty to reuse JWT_SECRET in development.
OIDC_STATE_SECRET=
OIDC_STATE_EXPIRES_IN_SECONDS=600
OIDC_HTTP_TIMEOUT_MS=5000
# Optional frontend callback URL. If set, GET /api/auth/sso/callback redirects here with result metadata.
OIDC_FRONTEND_CALLBACK_URL=
# Development only. Keep false in production; prefer client_secret_ref=env://YOUR_SECRET_VARIABLE.
OIDC_ALLOW_PLAIN_CLIENT_SECRET=false


# Seed / installer defaults
# These values are used by npm run seed, npm run check:install and reset-local-data.cmd.
SEED_ORGANISATION_NAME=Demo Organisation
SEED_ORGANISATION_SLUG=demo-organisation
SEED_ORGANISATION_DOMAIN=example.com
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_FIRST_NAME=Demo
SEED_ADMIN_LAST_NAME=Admin
SEED_PLAN_KEY=professional
# Set true only when you intentionally want npm run seed to replace the seeded admin password.
SEED_FORCE_ADMIN_PASSWORD_RESET=false
