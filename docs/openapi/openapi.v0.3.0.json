{
  "openapi": "3.0.3",
  "info": {
    "title": "SaaS Boilerplate API",
    "version": "0.3.0",
    "description": "Organisation-first SaaS boilerplate API. Every API is documented with Internal or External tags and explicit authentication requirements."
  },
  "servers": [
    {
      "url": "http://localhost:4000/api",
      "description": "Local development API"
    }
  ],
  "tags": [
    {
      "name": "External",
      "description": "APIs intended for use by application clients or external consumers. Authentication requirements are shown per endpoint."
    },
    {
      "name": "Internal",
      "description": "APIs intended for platform/admin/internal use. These usually require authentication and elevated permissions once auth is introduced."
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Future authenticated API access using a bearer token. Not active in v0.3.0 because authentication starts in v0.5.0."
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "object",
            "properties": {
              "message": {
                "type": "string",
                "example": "Route not found"
              },
              "details": {
                "type": "object"
              }
            }
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "success",
          "service",
          "version",
          "status",
          "database",
          "timestamp"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "service": {
            "type": "string",
            "example": "saas-boilerplate-api"
          },
          "version": {
            "type": "string",
            "example": "0.3.0"
          },
          "status": {
            "type": "string",
            "example": "ok"
          },
          "database": {
            "type": "object",
            "properties": {
              "mongo_ready_state": {
                "type": "number",
                "description": "Mongoose connection ready state. 1 means connected."
              }
            }
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "OrganisationDomain": {
        "type": "object",
        "required": [
          "domain"
        ],
        "properties": {
          "domain": {
            "type": "string",
            "example": "example.com"
          },
          "verified": {
            "type": "boolean",
            "example": false
          },
          "is_primary": {
            "type": "boolean",
            "example": true
          }
        }
      },
      "OrganisationPlan": {
        "type": "object",
        "properties": {
          "plan_id": {
            "type": "string",
            "nullable": true,
            "example": "foundation"
          },
          "name": {
            "type": "string",
            "nullable": true,
            "example": "Foundation"
          },
          "billing_status": {
            "type": "string",
            "nullable": true,
            "example": "not_configured"
          }
        }
      },
      "OrganisationBranding": {
        "type": "object",
        "properties": {
          "logo_url": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "primary_colour": {
            "type": "string",
            "nullable": true,
            "example": "#1A73E8"
          },
          "secondary_colour": {
            "type": "string",
            "nullable": true,
            "example": "#111827"
          },
          "login_title": {
            "type": "string",
            "nullable": true,
            "example": "Welcome to Example Organisation"
          },
          "login_subtitle": {
            "type": "string",
            "nullable": true,
            "example": "Sign in to continue"
          },
          "login_background_url": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "support_email": {
            "type": "string",
            "nullable": true,
            "example": "support@example.com"
          }
        }
      },
      "OrganisationStorage": {
        "type": "object",
        "properties": {
          "storage_provider": {
            "type": "string",
            "nullable": true,
            "example": null
          },
          "storage_prefix": {
            "type": "string",
            "nullable": true,
            "example": "organisations/example-organisation/"
          },
          "max_storage_gb": {
            "type": "number",
            "nullable": true,
            "example": 20
          }
        }
      },
      "Organisation": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "665000000000000000000001"
          },
          "_id": {
            "type": "string",
            "example": "665000000000000000000001"
          },
          "name": {
            "type": "string",
            "example": "Example Organisation"
          },
          "slug": {
            "type": "string",
            "example": "example-organisation"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive",
              "suspended"
            ],
            "example": "active"
          },
          "plan": {
            "$ref": "#/components/schemas/OrganisationPlan"
          },
          "branding": {
            "$ref": "#/components/schemas/OrganisationBranding"
          },
          "domains": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrganisationDomain"
            }
          },
          "auth_config": {
            "type": "object",
            "description": "Organisation auth configuration placeholder. Full SSO support is planned for later versions."
          },
          "features": {
            "type": "object",
            "additionalProperties": {
              "type": "boolean"
            },
            "example": {
              "dashboard": true,
              "file_uploads": false
            }
          },
          "compute_allocation": {
            "type": "object",
            "description": "Future compute allocation placeholder."
          },
          "storage": {
            "$ref": "#/components/schemas/OrganisationStorage"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateOrganisationRequest": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 200,
            "example": "Example Organisation"
          },
          "slug": {
            "type": "string",
            "example": "example-organisation",
            "description": "Optional. If omitted, the API generates one from the organisation name."
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive",
              "suspended"
            ],
            "default": "active"
          },
          "plan": {
            "$ref": "#/components/schemas/OrganisationPlan"
          },
          "branding": {
            "$ref": "#/components/schemas/OrganisationBranding"
          },
          "domains": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrganisationDomain"
            }
          },
          "features": {
            "type": "object",
            "additionalProperties": {
              "type": "boolean"
            }
          },
          "storage": {
            "$ref": "#/components/schemas/OrganisationStorage"
          }
        }
      },
      "UpdateOrganisationRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2,
            "maxLength": 200
          },
          "slug": {
            "type": "string",
            "example": "example-organisation-renamed"
          },
          "plan": {
            "$ref": "#/components/schemas/OrganisationPlan"
          },
          "branding": {
            "$ref": "#/components/schemas/OrganisationBranding"
          },
          "domains": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrganisationDomain"
            }
          },
          "features": {
            "type": "object",
            "additionalProperties": {
              "type": "boolean"
            }
          },
          "storage": {
            "$ref": "#/components/schemas/OrganisationStorage"
          }
        }
      },
      "UpdateOrganisationStatusRequest": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "active",
              "inactive",
              "suspended"
            ],
            "example": "suspended"
          }
        }
      },
      "OrganisationResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Organisation created successfully."
          },
          "data": {
            "$ref": "#/components/schemas/Organisation"
          }
        }
      },
      "OrganisationListResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Organisation"
            }
          },
          "pagination": {
            "type": "object",
            "properties": {
              "page": {
                "type": "number",
                "example": 1
              },
              "limit": {
                "type": "number",
                "example": 20
              },
              "total": {
                "type": "number",
                "example": 1
              },
              "total_pages": {
                "type": "number",
                "example": 1
              }
            }
          }
        }
      },
      "SchemaStatusResponse": {
        "type": "object",
        "required": [
          "success",
          "version",
          "message",
          "tenant_model",
          "authentication",
          "collection_status",
          "timestamp"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "version": {
            "type": "string",
            "example": "0.3.0"
          },
          "message": {
            "type": "string",
            "example": "MongoDB schema foundation is loaded."
          },
          "tenant_model": {
            "type": "string",
            "example": "Organisation -> Users. Users require organisation_id and cannot belong to more than one organisation."
          },
          "authentication": {
            "type": "object",
            "properties": {
              "required": {
                "type": "boolean",
                "example": false
              },
              "note": {
                "type": "string",
                "example": "Authentication is introduced in v0.5.0. Internal routes are unauthenticated only during foundation builds."
              }
            }
          },
          "collection_status": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "model": {
                  "type": "string",
                  "example": "Organisation"
                },
                "collection": {
                  "type": "string",
                  "example": "organisations"
                },
                "indexes_declared": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                },
                "estimated_document_count": {
                  "type": "number",
                  "example": 1
                }
              }
            }
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "External"
        ],
        "summary": "Health check",
        "description": "Returns API service status, version and MongoDB connection ready state. Authentication: none.",
        "operationId": "getHealth",
        "security": [],
        "responses": {
          "200": {
            "description": "API health status returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/internal/schema/status": {
      "get": {
        "tags": [
          "Internal"
        ],
        "summary": "MongoDB schema foundation status",
        "description": "Internal diagnostic route showing loaded Mongoose models, indexes and estimated collection counts. Authentication: none in v0.3.0; will require authenticated internal/admin access after auth is introduced.",
        "operationId": "getSchemaFoundationStatus",
        "security": [],
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchemaStatusResponse"
                }
              }
            }
          }
        }
      }
    },
    "/platform/organisations": {
      "post": {
        "tags": [
          "Internal"
        ],
        "summary": "Create organisation",
        "description": "Creates a new organisation tenant. Authentication: none in v0.3.0 foundation build; intended future access is platform admin only. This is an internal/platform API.",
        "operationId": "createOrganisation",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrganisationRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Organisation created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Organisation slug already exists.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Internal"
        ],
        "summary": "List organisations",
        "description": "Lists organisation tenants with pagination and optional status/search filters. Authentication: none in v0.3.0 foundation build; intended future access is platform admin only.",
        "operationId": "listOrganisations",
        "security": [],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "active",
                "inactive",
                "suspended"
              ]
            }
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string",
              "maxLength": 120
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/platform/organisations/{id}": {
      "get": {
        "tags": [
          "Internal"
        ],
        "summary": "Get organisation by id",
        "description": "Returns one organisation tenant by MongoDB object id. Authentication: none in v0.3.0 foundation build; intended future access is platform admin only.",
        "operationId": "getOrganisationById",
        "security": [],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationResponse"
                }
              }
            }
          },
          "404": {
            "description": "Organisation not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "Internal"
        ],
        "summary": "Update organisation profile",
        "description": "Updates profile/configuration fields for one organisation. Status changes are handled by the dedicated status endpoint. Authentication: none in v0.3.0 foundation build; intended future access is platform admin only.",
        "operationId": "updateOrganisation",
        "security": [],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateOrganisationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Organisation not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Organisation slug already exists.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/platform/organisations/{id}/status": {
      "patch": {
        "tags": [
          "Internal"
        ],
        "summary": "Update organisation status",
        "description": "Updates organisation status to active, inactive or suspended. Authentication: none in v0.3.0 foundation build; intended future access is platform admin only.",
        "operationId": "updateOrganisationStatus",
        "security": [],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateOrganisationStatusRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Organisation not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/openapi.json": {
      "get": {
        "tags": [
          "Internal"
        ],
        "summary": "OpenAPI specification",
        "description": "Returns the current OpenAPI specification. Authentication: none in v0.3.0; can be restricted to internal/admin users after authentication is introduced.",
        "operationId": "getOpenApiSpec",
        "security": [],
        "responses": {
          "200": {
            "description": "OpenAPI specification returned successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/docs": {
      "get": {
        "tags": [
          "Internal"
        ],
        "summary": "Swagger UI documentation",
        "description": "Interactive Swagger UI for the current API specification. Authentication: none in v0.3.0; can be restricted to internal/admin users after authentication is introduced.",
        "operationId": "getSwaggerUi",
        "security": [],
        "responses": {
          "200": {
            "description": "Swagger UI HTML returned successfully."
          }
        }
      }
    }
  }
}
