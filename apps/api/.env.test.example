NODE_ENV=test
PORT=0
API_BASE_PATH=/api
MONGODB_URI=mongodb://localhost:27017/saas_boilerplate_test
TEST_MONGODB_URI=mongodb://localhost:27017/saas_boilerplate_test
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-test-jwt-secret-at-least-32-characters
JWT_EXPIRES_IN_SECONDS=3600
OIDC_STATE_SECRET=replace-with-test-oidc-state-secret-at-least-32-characters
OIDC_ALLOW_PLAIN_CLIENT_SECRET=true
STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=apps/api/storage-test

# v0.18.2 testing mode
# Default integration testing uses TEST_MONGODB_URI/local Docker MongoDB.
# Set true only when you want mongodb-memory-server to download/run an ephemeral MongoDB binary.
USE_MONGODB_MEMORY_SERVER=false
